# =============================================================================
# AirGuard Air Pollution Monitoring Agent System v4
# Environment Configuration
#
# HOW TO USE:
#   1. Copy this file:   cp .env.example .env
#   2. Open .env and fill in your actual values
#   3. Never commit .env to git — add it to .gitignore
#   4. This file (.env.example) is safe to commit — it contains no real secrets
#
# RUN MODES (selected automatically):
#   DEMO     — no API key needed, stdlib only, full structured output
#   LANGGRAPH — LangGraph installed, no API key, real graph topology
#   LIVE LLM  — OPENAI_API_KEY set, full GPT-4o reasoning
#   LIVE MCP  — OPENAI_API_KEY + ANTHROPIC_API_KEY, Gmail + Calendar integrations
#
# REGULATORY DISCLAIMER:
#   This system provides decision support only.
#   All public health advisories, enforcement actions, and mitigation orders
#   must be reviewed and issued by authorized regulatory personnel.
# =============================================================================


# -----------------------------------------------------------------------------
# LLM — REQUIRED FOR LIVE MODE
# -----------------------------------------------------------------------------

# Your OpenAI API key.
# Get one at: https://platform.openai.com/api-keys
# Must start with sk- to be recognised as valid.
# If missing or blank, the system runs in DEMO mode automatically.
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI model for all agent LLM calls.
# Options:
#   gpt-4o       — best multi-domain reasoning for air quality analysis (default)
#   gpt-4o-mini  — cheaper, suitable for testing only
# Default: gpt-4o
OPENAI_MODEL=gpt-4o

# LLM temperature — very low for consistent regulatory decisions.
# Default: 0.05
OPENAI_TEMPERATURE=0.05


# -----------------------------------------------------------------------------
# ANTHROPIC API — REQUIRED FOR LIVE MCP (Gmail + Google Calendar)
# -----------------------------------------------------------------------------

# Your Anthropic API key — used only for MCP tool calls (Gmail, Google Calendar).
# Get one at: https://console.anthropic.com/
# Must start with sk-ant- to be recognised as valid.
# If missing, all MCP tool calls run in demo mode (no emails sent, no calendar events created).
# The OpenAI key (above) is still used for all LLM reasoning — this key is only for MCP.
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Anthropic model used exclusively for MCP calls.
# Do not change this unless Anthropic releases a newer MCP-compatible model.
# Default: claude-sonnet-4-20250514
ANTHROPIC_MCP_MODEL=claude-sonnet-4-20250514


# -----------------------------------------------------------------------------
# NETWORK IDENTITY — OPTIONAL (defaults shown)
# -----------------------------------------------------------------------------

# Name of the air quality monitoring system as it appears in all reports and alerts.
# Default: AirGuard Pollution Monitoring System
SYSTEM_NAME=AirGuard Pollution Monitoring System

# City and region being monitored — appears in all public alerts and situation reports.
# Default: Metro City
CITY=Metro City
REGION=Central Metropolitan Region


# -----------------------------------------------------------------------------
# MONITORING THRESHOLDS — OPTIONAL (defaults shown)
# Based on WHO Air Quality Guidelines 2021 and US EPA AQI breakpoints.
# Change only if your jurisdiction applies different regulatory limits.
# -----------------------------------------------------------------------------

# WHO 24-hour guideline limits (ug/m3)
PM25_WHO_24H=15.0
PM10_WHO_24H=45.0
SO2_WHO_24H=40.0
NO2_WHO_1H=200.0
O3_WHO_8H=100.0
# CO limit in mg/m3
CO_WHO_8H=4.0

# US EPA AQI category breakpoints (AQI score)
AQI_GOOD=50
AQI_MODERATE=100
AQI_UNHEALTHY_SENSITIVE=150
AQI_UNHEALTHY=200
AQI_VERY_UNHEALTHY=300
AQI_HAZARDOUS=500


# -----------------------------------------------------------------------------
# MONITORING LOOP — OPTIONAL (defaults shown)
# Controls multi-run monitoring cycle behaviour (--runs N flag in main.py).
# -----------------------------------------------------------------------------

# Delay in seconds between monitoring cycle runs when using --runs N.
# Default: 1800 (30 minutes — matches typical AQMD polling interval)
MONITORING_INTERVAL_SECONDS=1800

# Maximum number of ReAct agent iterations per run.
# Increase for complex episode scenarios with many enforcement actions.
# Default: 20
MAX_REACT_ITERATIONS=20


# -----------------------------------------------------------------------------
# GROUND SENSOR NETWORK — OPTIONAL
# Production data source for ground station readings.
# Leave blank to use simulation data (date-seeded, reproducible).
# -----------------------------------------------------------------------------

# OpenAQ Platform API — global aggregator, 100+ country networks
# Free tier: 10 requests/minute, hourly averages
# Docs: https://docs.openaq.org/
OPENAQ_API_KEY=

# US EPA AirNow API — regulatory-grade US ground sensor network
# Free registration at: https://docs.airnowapi.org/
AIRNOW_API_KEY=

# State AQMD SCADA / telemetry feed — real-time compliance monitoring data
# Endpoint and credentials provided by your state air quality management district
# Example: https://api.your-aqmd.gov/telemetry/v1
AQMD_API_BASE_URL=
AQMD_API_KEY=

# Sensor network polling interval in seconds.
# Most AQMD networks update every 5-15 minutes.
# Default: 300 (5 minutes)
SENSOR_POLL_INTERVAL_SECONDS=300


# -----------------------------------------------------------------------------
# SATELLITE DATA — OPTIONAL
# Production source for aerosol optical depth, NO2 columns, fire detection.
# Leave blank to use simulation data.
# -----------------------------------------------------------------------------

# Google Earth Engine project ID — pulls Sentinel-5P, MODIS, Landsat-9
# Register at: https://earthengine.google.com/
# Collections used:
#   COPERNICUS/S5P/OFFL/L3_NO2   (Sentinel-5P NO2)
#   COPERNICUS/S5P/OFFL/L3_AER_AI (Sentinel-5P Aerosol)
#   MODIS/006/MOD04_3K            (MODIS AOD)
#   MODIS/006/MOD14A1             (MODIS Active Fires)
#   LANDSAT/LC09/C02/T1_L2        (Landsat-9 Surface Temp)
GEE_PROJECT_ID=

# NASA EarthData credentials — direct LAADS DAAC access for MODIS products
# Register at: https://urs.earthdata.nasa.gov/
NASA_EARTHDATA_USERNAME=
NASA_EARTHDATA_PASSWORD=

# ESA Copernicus Open Access Hub — Sentinel-5P Level-2 products
# Register at: https://scihub.copernicus.eu/
COPERNICUS_USERNAME=
COPERNICUS_PASSWORD=


# -----------------------------------------------------------------------------
# METEOROLOGICAL DATA — OPTIONAL
# Leave blank to use simulation data.
# -----------------------------------------------------------------------------

# NOAA HRRR / NDFD model output — 3km resolution, continental US
# Free API, no key required — specify region bounding box below
# Docs: https://www.ncei.noaa.gov/products/weather-forecast-guidance
NOAA_API_BASE_URL=https://api.weather.gov

# Meteomatics API — global high-resolution forecasts including mixing height
# and Pasquill-Gifford stability class (critical for dispersion modelling)
# Register at: https://www.meteomatics.com/en/api/
METEOMATICS_USERNAME=
METEOMATICS_PASSWORD=

# Tomorrow.io — hyper-local hourly forecasts with field-level resolution
# Register at: https://www.tomorrow.io/weather-api/
TOMORROWIO_API_KEY=

# Farm/monitoring location bounding box (used for NOAA and GEE queries)
# Format: decimal degrees
MONITORING_LAT=40.7128
MONITORING_LON=-74.0060
MONITORING_RADIUS_KM=50


# -----------------------------------------------------------------------------
# EMISSION INVENTORY — OPTIONAL
# Production source for registered sources, permit limits, compliance status.
# Leave blank to use the built-in static inventory.
# -----------------------------------------------------------------------------

# US EPA Facility Registry Service (FRS) / NEI API
# Docs: https://www.epa.gov/enviro/envirofacts-data-service-api
EPA_FRS_API_KEY=

# State AQMD permit database API
# Credentials provided by your state AQMD
# Example: https://permits.your-aqmd.gov/api/v1
AQMD_PERMIT_API_BASE_URL=
AQMD_PERMIT_API_KEY=


# -----------------------------------------------------------------------------
# PUBLIC ALERT DISPATCH — OPTIONAL
# Production channels for broadcasting public health alerts.
# Leave blank — alerts are logged internally but not dispatched externally.
# -----------------------------------------------------------------------------

# Everbridge — mass notification platform for emergency alerts
# Used for: public emergency SMS, app push, digital signage, social media
# Register at: https://www.everbridge.com/
EVERBRIDGE_API_URL=
EVERBRIDGE_API_KEY=
EVERBRIDGE_ORG_ID=

# Rave Mobile Safety — alternative mass notification platform
# Register at: https://www.ravemobilesafety.com/
RAVE_API_KEY=

# Twilio — direct SMS gateway for public and care-team alerts
# Register at: https://console.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# US EPA AirNow — submit air quality data to the national public portal
# Requires authorised data submitter registration with EPA
AIRNOW_REPORTING_KEY=

# City digital signage API — update outdoor air quality displays
SIGNAGE_API_URL=
SIGNAGE_API_KEY=


# -----------------------------------------------------------------------------
# REGULATORY ENFORCEMENT DISPATCH — OPTIONAL
# Production channels for issuing enforcement actions to regulated facilities.
# Leave blank — enforcement actions are logged internally only.
# -----------------------------------------------------------------------------

# State AQMD enforcement database — write violation records and orders
AQMD_ENFORCEMENT_API_URL=
AQMD_ENFORCEMENT_API_KEY=

# Email address of AQMD Enforcement Director (for MCP Gmail notifications)
# Populated automatically in mcp_tools.py send_incident_notification_email()
ENFORCEMENT_DIRECTOR_EMAIL=enforcement.director@your-aqmd.gov

# Operations centre email — copied on all emergency notifications
OPS_CENTER_EMAIL=ops.center@your-aqmd.gov


# -----------------------------------------------------------------------------
# HOSPITAL NETWORK — OPTIONAL
# Production channel for clinical preparedness alerts to hospital networks.
# Leave blank — hospital alerts are logged internally only.
# -----------------------------------------------------------------------------

# HAvBED2 hospital capacity system endpoint
# Provided by your regional health authority
HAVBED_API_URL=
HAVBED_API_KEY=

# HL7 FHIR endpoint — dispatch clinical alerts to hospital EHR systems
HOSPITAL_FHIR_BASE_URL=
HOSPITAL_FHIR_ACCESS_TOKEN=


# -----------------------------------------------------------------------------
# TRAFFIC MANAGEMENT — OPTIONAL
# Production channel for Low Emission Zone and HGV restriction activation.
# Leave blank — traffic restrictions are logged internally only.
# -----------------------------------------------------------------------------

# City ATMS (Advanced Traffic Management System) API
# Provided by city transport authority
ATMS_API_URL=
ATMS_API_KEY=

# ANPR (Automatic Number Plate Recognition) enforcement system
# Used for LEZ zone entry enforcement
ANPR_API_URL=
ANPR_API_KEY=


# -----------------------------------------------------------------------------
# MCP CALENDAR — OPTIONAL
# Google Calendar configuration for incident tracking calendar.
# The MCP server handles OAuth — no token management required here.
# Leave blank — calendar events are created in demo mode only.
# -----------------------------------------------------------------------------

# Name of the Google Calendar used for incident tracking.
# The calendar must exist in the connected Google account.
# Default: AirGuard Incident Tracking
INCIDENT_CALENDAR_NAME=AirGuard Incident Tracking


# -----------------------------------------------------------------------------
# LOGGING — OPTIONAL (defaults shown)
# -----------------------------------------------------------------------------

# Log level.
# Options: DEBUG, INFO, WARNING, ERROR
# Default: INFO
LOG_LEVEL=INFO

# Audit log file — records every alert issued, enforcement action taken,
# and MCP call made for regulatory compliance and incident review.
AUDIT_LOG_FILE=

# Retain audit logs for this many days.
# Recommended minimum for environmental enforcement compliance: 1825 (5 years)
# Default: 1825
AUDIT_LOG_RETENTION_DAYS=1825
